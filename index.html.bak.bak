<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Faulo & Marvie | Wedding Invitation</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Lora:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    :root{
      --ink:#6f4b35;
      --muted:#8f6f61;
      --accent:#c88f8a;
      --accent-deep:#ab746d;
      --blush:#f2d6d4;
      --butter:#f3e3b8;
      --line:rgba(111,75,53,.12);
      --shadow:0 14px 34px rgba(170,129,110,.10);
      --radius:24px;
      --nav-h:82px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body{
      margin:0;
      font-family:'Lora', serif;
      color:var(--ink);
      background:#fdf7f4;
      line-height:1.75;
      overflow-x:hidden;
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
    }

    h1,h2,h3,h4,h5,h6,.display-font{
      font-family:'Cormorant Garamond', serif;
      color:var(--ink);
      line-height:1.08;
      margin-bottom:.6rem;
    }

    p,li,a,button,input,select,textarea{
      font-family:'Lora', serif;
      color:var(--ink);
    }

    img{
      max-width:100%;
      display:block;
    }

    .section-padding{
      padding:88px 0;
      position:relative;
    }

    .section-title{
      text-align:center;
      font-size:clamp(2.1rem,4vw,3.4rem);
      color:#8f623f;
      margin-bottom:.55rem;
    }

    .section-subtitle{
      text-align:center;
      max-width:820px;
      margin:0 auto 2rem;
      color:var(--muted);
      font-size:1.03rem;
    }

    .section-kicker{
      text-align:center;
      color:#9b7b6c;
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1.05rem,2vw,1.35rem);
      margin-bottom:1.35rem;
    }

    .soft-card{
      background:#fff;
      border:1px solid rgba(200,143,138,.22);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
      position:relative;
    }

    .floral-corner::before,
    .floral-corner::after{
      content:'✿';
      position:absolute;
      font-size:1rem;
      color:rgba(200,143,138,.18);
      pointer-events:none;
      z-index:1;
    }

    .floral-corner::before{ top:14px; left:16px; }
    .floral-corner::after{ bottom:14px; right:16px; }

    /* preserved section background colors */
    .save-the-date{ background:#fff; }
    #story{ background:#f3e3b8; }
    #celebration{ background:#fff; }
    #attire{ background:#f2d6d4; }
    #entourage{ background:#fff; }
    #gallery{ background:#f4e5b6; }
    #reminders{ background:#fff; }
    #rsvp{ background:#f2d6d4; }

    /* navbar */
    .navbar{
      background:rgba(242,214,212,.92);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(155,95,116,.10);
      min-height:var(--nav-h);
    }

    .nav-logo{
      height:60px;
      width:auto;
      object-fit:contain;
    }

    .navbar-nav .nav-link{
      color:var(--ink)!important;
      font-size:.96rem;
      font-weight:500;
      letter-spacing:.03em;
    }

    .navbar-nav .nav-link:hover{
      color:var(--accent)!important;
    }

    .navbar-toggler{
      border-color:rgba(111,75,53,.18);
    }

    .navbar-toggler:focus{
      box-shadow:none;
    }

    /* HERO */
    .hero{
      min-height:100svh;
      padding-top:var(--nav-h);
      position:relative;
      display:flex;
      align-items:center;
      background:
        linear-gradient(rgba(28,21,16,.42), rgba(28,21,16,.52)),
        url('1.jpg') center center / cover no-repeat;
      isolation:isolate;
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 50% 32%, rgba(255,255,255,.08), transparent 40%),
        linear-gradient(to bottom, rgba(0,0,0,.06), rgba(0,0,0,.18));
      z-index:0;
      pointer-events:none;
    }

    .hero .container{
      position:relative;
      z-index:2;
    }

    .hero-wrap{
      min-height:calc(100svh - var(--nav-h));
      display:grid;
      place-items:center;
      padding:2rem 0;
    }

    .hero-panel{
      width:min(100%, 760px);
      padding:clamp(1.25rem, 3vw, 2rem);
      border-radius:28px;
      background:rgba(255,255,255,.16);
      backdrop-filter:blur(8px);
      -webkit-backdrop-filter:blur(8px);
      border:1px solid rgba(255,255,255,.28);
      box-shadow:0 12px 40px rgba(0,0,0,.14);
      text-align:center;
    }

    .hero-overline{
      letter-spacing:.22em;
      text-transform:uppercase;
      color:#fff7f2;
      font-size:.78rem;
      margin-bottom:.55rem;
    }

    .hero-names{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(3rem, 8vw, 5.6rem);
      line-height:.95;
      color:#fff;
      margin:0 0 .7rem;
      text-shadow:0 2px 18px rgba(0,0,0,.28);
    }

    .hero-date{
      font-family:'Cormorant Garamond', serif;
      color:#fff;
      font-size:clamp(1.15rem, 2.6vw, 1.7rem);
      margin-bottom:.45rem;
    }

    .hero-place{
      color:rgba(255,255,255,.92);
      max-width:42rem;
      margin:0 auto 1.2rem;
      font-size:1rem;
    }

    .hero-actions{
      display:flex;
      align-items:center;
      justify-content:center;
      flex-wrap:wrap;
      gap:.75rem;
      margin-bottom:1rem;
    }

    .hero-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:180px;
      padding:.78rem 1.35rem;
      border-radius:999px;
      text-decoration:none;
      font-weight:700;
      letter-spacing:.1em;
      text-transform:uppercase;
      font-size:.9rem;
      transition:.25s ease;
    }

    .hero-btn-primary{
      background:#e6b8b6;
      color:#fff;
      border:1px solid rgba(230,184,182,.94);
    }

    .hero-btn-primary:hover{
      color:#fff;
      transform:translateY(-1px);
      filter:brightness(.98);
    }

    .hero-btn-secondary{
      background:rgba(255,255,255,.14);
      color:#fff;
      border:1px solid rgba(255,255,255,.42);
    }

    .hero-btn-secondary:hover{
      color:#fff;
      background:rgba(255,255,255,.20);
    }

    .hero-verse{
      display:inline-block;
      padding:.75rem 1rem;
      border-radius:18px;
      background:rgba(255,255,255,.92);
      color:#2d2d2d;
      box-shadow:0 6px 18px rgba(0,0,0,.08);
      max-width:520px;
      font-size:.97rem;
      line-height:1.55;
    }

    .hero-verse strong{
      display:block;
      font-family:'Cormorant Garamond', serif;
      font-size:1.15rem;
      color:#3b2a20;
    }

    .hero-verse span{
      display:block;
      color:#8d6b5f;
      margin-top:.2rem;
      font-size:.92rem;
    }

    /* save the date */
    .save-wrap{
      max-width:980px;
      margin:0 auto;
      text-align:center;
    }

    .save-icon-row{
      display:flex;
      justify-content:center;
      gap:1rem;
      align-items:center;
      margin-bottom:.85rem;
    }

    .save-icon-side{
      font-size:1.5rem;
      color:#ab746d;
    }

    .save-icon-center{
      font-size:2.8rem;
      color:var(--ink);
    }

    .save-intro-line{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1rem,2vw,1.2rem);
      text-transform:uppercase;
      letter-spacing:.08em;
      color:#b88b78;
      margin-bottom:.15rem;
    }

    .save-intro-names{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(2.6rem,6vw,4.8rem);
      font-weight:600;
      color:#9a6a45;
      line-height:1;
      margin-bottom:.4rem;
    }

    .save-label{
      letter-spacing:.16em;
      text-transform:uppercase;
      font-size:.8rem;
      color:#b88b78;
      margin-bottom:.2rem;
    }

    .save-date-line{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1.8rem,4vw,3.2rem);
      color:#9a6a45;
      margin-bottom:.25rem;
    }

    .save-location{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1rem,2vw,1.3rem);
      color:#b7897c;
      margin-bottom:1.65rem;
    }

    .countdown-wrap{
      background:#fff;
      max-width:820px;
      margin:0 auto;
      border-top:1px solid rgba(200,143,138,.28);
      border-bottom:1px solid rgba(200,143,138,.28);
      padding:1.4rem 1rem;
    }

    .countdown{
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:.65rem;
      text-align:center;
    }

    .count-number{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(2rem, 6vw, 4.2rem);
      color:#9a6a45;
      line-height:1;
    }

    .count-label{
      text-transform:uppercase;
      font-size:.78rem;
      color:#b88b78;
      letter-spacing:.11em;
      margin-top:.25rem;
    }

    /* story */
    .story-img-wrap{
      min-height:520px;
      border-radius:30px;
      overflow:hidden;
      box-shadow:var(--shadow);
      position:relative;
      height:100%;
    }

    .story-img-wrap .carousel-inner,
    .story-img-wrap .carousel-item{
      height:100%;
    }

    .story-img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    .story-card{
      height:100%;
      border-radius:30px;
      background:#f2d6d4;
      border:1.5px solid rgba(243,216,223,.55);
      box-shadow:0 14px 34px rgba(0,0,0,.06), 0 0 0 6px rgba(245,230,171,.10);
    }

    .story-card-inner{
      padding:2.5rem 2.2rem;
      height:100%;
      display:flex;
      flex-direction:column;
      justify-content:center;
    }

    .story-step{
      padding-left:1rem;
      border-left:2px solid rgba(243,216,223,.55);
      margin-bottom:1.15rem;
    }

    .story-step:last-child{ margin-bottom:0; }
    .story-step p{ margin:0; font-size:1.08rem; }

    .story-carousel-btn{
      width:42px;
      opacity:0;
      transition:opacity .25s ease;
    }

    .story-img-wrap:hover .story-carousel-btn{
      opacity:1;
    }

    .story-carousel-btn .carousel-control-prev-icon,
    .story-carousel-btn .carousel-control-next-icon{
      background-color:rgba(255,255,255,.46);
      border-radius:50%;
      background-size:55% 55%;
      width:2.2rem;
      height:2.2rem;
      backdrop-filter:blur(3px);
    }

    /* celebration */
    .celebration-card{
      padding:1.25rem;
      background:linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,247,240,.9));
    }

    .celebration-visual{
      height:100%;
      min-height:340px;
      border-radius:20px;
      overflow:hidden;
      box-shadow:var(--shadow);
    }

    .celebration-visual img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    .celebration-content{
      padding:1rem 1rem 1rem 2rem;
      height:100%;
    }

    .eyebrow{
      display:inline-block;
      font-size:.78rem;
      letter-spacing:.16em;
      text-transform:uppercase;
      color:var(--accent);
      margin-bottom:.6rem;
    }

    .detail-title{
      font-size:1.8rem;
      color:#8f623f;
    }

    .detail-meta{
      color:#9b7b6c;
      margin-bottom:.85rem;
      font-size:.95rem;
    }

    .mini-card{
      height:100%;
      border-radius:18px;
      border:1px solid rgba(155,95,116,.14);
      background:#f2d6d4;
      padding:1rem .75rem;
      text-align:center;
    }

    .mini-card h4{
      font-size:1.2rem;
      color:var(--accent-deep);
      margin-bottom:.25rem;
    }

    .mini-card p{
      margin:0;
      font-family:'Cormorant Garamond', serif;
      font-size:1.1rem;
    }

    .map-frame{
      width:100%;
      border:0;
      height:240px;
      border-radius:18px;
      margin-top:.8rem;
    }

    /* attire */
    .guide-card{
      background:linear-gradient(180deg, rgba(255,252,249,.96), rgba(255,246,240,.94));
      border-radius:30px;
      padding:2.2rem;
    }

    .guide-copy{
      font-size:1rem;
      color:var(--ink);
    }

    .palette-strip{
      background:rgba(255,255,255,.78);
      border:1px solid rgba(42,36,31,.10);
      padding:1rem 1rem .9rem;
      margin-bottom:1rem;
    }

    .swatches{
      display:flex;
      gap:.75rem;
      flex-wrap:wrap;
      justify-content:center;
      margin-bottom:.7rem;
    }

    .swatch{
      width:40px;
      height:40px;
      border-radius:50%;
      border:1px solid rgba(17,17,17,.08);
      box-shadow:0 3px 8px rgba(0,0,0,.05);
    }

    .palette-caption,
    .guide-note-small{
      text-align:center;
      color:var(--muted);
      font-size:.86rem;
      line-height:1.55;
      margin:0;
    }

    .guide-no-row{
      display:flex;
      justify-content:center;
      gap:.7rem;
      flex-wrap:wrap;
      margin-top:.2rem;
    }

    .swatch.x-mark{
      position:relative;
    }

    .swatch.x-mark::before,
    .swatch.x-mark::after{
      content:'';
      position:absolute;
      width:56px;
      height:4px;
      background:#000;
      top:50%;
      left:50%;
      border-radius:999px;
      transform-origin:center;
    }

    .swatch.x-mark::before{ transform:translate(-50%,-50%) rotate(32deg); }
    .swatch.x-mark::after{ transform:translate(-50%,-50%) rotate(-32deg); }

    /* entourage */
    .entourage-block{
      padding:1.55rem 1rem;
      border:1px solid rgba(155,95,116,.11);
      margin-bottom:1.2rem;
    }

    .entourage-block.pink{ background:#f2d6d4; }
    .entourage-block.butter{ background:#f4e5b6; }

    .entourage-card-header{
      text-align:center;
      font-size:clamp(2rem, 4vw, 3.1rem);
      color:#8f623f;
      margin-bottom:.45rem;
    }

    .entourage-subtext{
      text-align:center;
      color:var(--accent);
      font-family:'Cormorant Garamond', serif;
      font-size:1rem;
      font-style:italic;
      margin-bottom:1rem;
    }

    .entourage-group-title{
      text-align:center;
      text-transform:uppercase;
      letter-spacing:.05em;
      font-size:clamp(1.05rem,2vw,1.4rem);
      color:var(--accent-deep);
      margin-bottom:.4rem;
    }

    .name-list{
      list-style:none;
      padding:0;
      margin:0;
      text-align:center;
    }

    .name-list li{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1rem,1.8vw,1.2rem);
      line-height:1.45;
      margin-bottom:.08rem;
    }

    /* gallery */
    .gallery-item{
      position:relative;
      overflow:hidden;
      border-radius:22px;
      cursor:pointer;
      box-shadow:var(--shadow);
      height:250px;
      background:#efe8e3;
    }

    .gallery-item img{
      width:100%;
      height:100%;
      object-fit:cover;
      transition:transform .35s ease;
    }

    .gallery-item:hover img{
      transform:scale(1.05);
    }

    .gallery-overlay{
      position:absolute;
      inset:0;
      background:linear-gradient(to top, rgba(0,0,0,.34), rgba(0,0,0,.02));
      display:flex;
      align-items:flex-end;
      padding:1rem;
      color:#fff;
      opacity:0;
      transition:opacity .25s ease;
      font-family:'Cormorant Garamond', serif;
      font-size:1.05rem;
    }

    .gallery-item:hover .gallery-overlay{
      opacity:1;
    }

    /* reminders */
    .faq-top-grid{
      margin-top:.5rem;
      margin-bottom:1.8rem;
    }

    .reminder-card{
      background:#fff;
      border:1px solid rgba(154,106,69,.14);
      border-radius:28px;
      min-height:185px;
      padding:1.2rem .9rem;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      box-shadow:0 10px 24px rgba(0,0,0,.03);
      height:100%;
    }

    .reminder-card-inner{
      width:100%;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:.8rem;
    }

    .reminder-icon-wrap{
      width:64px;
      height:64px;
      border-radius:50%;
      background:#fbf5f2;
      border:1px solid rgba(154,106,69,.12);
      display:flex;
      align-items:center;
      justify-content:center;
      margin:0 auto;
    }

    .reminder-icon{
      width:32px;
      height:32px;
      stroke:#9a6a45;
      stroke-width:1.8;
      fill:none;
    }

    .reminder-label{
      color:#8d5f3e;
      font-size:clamp(1.25rem,2vw,1.85rem);
      line-height:1.15;
      margin:0;
      font-family:'Cormorant Garamond', serif;
    }

    .faq-title{
      text-align:center;
      color:#9a6a45;
      font-size:clamp(2.3rem,4.6vw,4rem);
      line-height:1.08;
      margin:2rem 0 1.3rem;
      font-family:'Cormorant Garamond', serif;
    }

    .facts-list{
      max-width:980px;
      margin:0 auto;
    }

    .fact-item{
      text-align:center;
      margin-bottom:1.45rem;
      padding:0;
    }

    .fact-item:last-child{ margin-bottom:0; }

    .fact-item h3{
      color:#9a6a45;
      font-size:clamp(1.55rem,3vw,2.2rem);
      line-height:1.15;
      margin-bottom:.45rem;
      text-transform:uppercase;
      font-family:'Cormorant Garamond', serif;
    }

    .fact-item p{
      max-width:900px;
      margin:0 auto;
      color:#6f4b35;
      font-size:clamp(1rem,1.5vw,1.16rem);
      line-height:1.8;
    }

    /* rsvp */
    .rsvp-panel{
      text-align:center;
      padding:2rem 1.1rem;
      border-top:2px solid var(--accent);
      position:relative;
      background:linear-gradient(180deg, rgba(255,251,246,.95), rgba(255,247,236,.92));
    }

    .rsvp-panel::before,
    .rsvp-panel::after{
      content:'✿';
      position:absolute;
      top:16px;
      font-size:.95rem;
      color:rgba(155,95,116,.45);
    }

    .rsvp-panel::before{ left:22px; }
    .rsvp-panel::after{ right:22px; }

    .rsvp-heading{
      font-size:clamp(1.9rem,4vw,2.8rem);
      color:#8f623f;
      margin-bottom:.8rem;
    }

    .rsvp-copy{
      max-width:700px;
      margin:0 auto .8rem;
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1.05rem,2vw,1.35rem);
    }

    .rsvp-cheers{
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1.05rem,2vw,1.35rem);
      margin-bottom:1rem;
    }

    .rsvp-button-wrap{
      display:inline-block;
      border:1px solid rgba(17,17,17,.35);
      padding:.28rem;
    }

    .rsvp-button{
      display:inline-block;
      min-width:220px;
      padding:.58rem 1.2rem;
      color:var(--ink);
      font-family:'Cormorant Garamond', serif;
      font-size:clamp(1.2rem,2vw,1.6rem);
      font-weight:600;
      text-decoration:underline;
      text-underline-offset:4px;
      background:transparent;
      border:none;
    }

    .rsvp-button:hover{
      color:var(--accent-deep);
    }

    footer{
      text-align:center;
      padding:2rem 0 3rem;
      color:var(--muted);
      border-top:1px solid var(--line);
      background:linear-gradient(180deg, #fffaf4, #fcf7ef);
    }

    .modal-content{
      background:transparent;
      border:none;
    }

    .modal-image{
      width:100%;
      max-height:82vh;
      object-fit:contain;
      border-radius:20px;
    }

    /* mobile */
    @media (max-width: 991.98px){
      .section-padding{ padding:72px 0; }
      .story-img-wrap{ min-height:380px; }
      .celebration-visual{ min-height:260px; margin-bottom:1rem; }
      .celebration-content{ padding:1rem .35rem 0; }
    }

    @media (max-width: 767.98px){
      :root{ --nav-h:74px; }

      .nav-logo{ height:52px; }

      .hero{
        min-height:100svh;
        background:
          linear-gradient(rgba(18,13,10,.50), rgba(18,13,10,.58)),
          url('1.jpg') center center / cover no-repeat;
      }

      .hero-wrap{
        min-height:calc(100svh - var(--nav-h));
        padding:1rem 0 1.5rem;
      }

      .hero-panel{
        border-radius:22px;
        padding:1rem;
      }

      .hero-names{
        font-size:clamp(2.6rem, 12vw, 4.2rem);
      }

      .hero-place{
        font-size:.95rem;
      }

      .hero-actions{
        flex-direction:column;
      }

      .hero-btn{
        width:100%;
        min-width:0;
      }

      .countdown{
        grid-template-columns:repeat(2,1fr);
        row-gap:1rem;
      }

      .story-img-wrap{
        min-height:260px;
        border-radius:24px;
      }

      .story-card{
        border-radius:24px;
      }

      .story-card-inner{
        padding:1.35rem 1rem;
      }

      .story-step p{
        font-size:.98rem;
      }

      .story-carousel-btn{
        opacity:1;
        width:36px;
      }

      .story-carousel-btn .carousel-control-prev-icon,
      .story-carousel-btn .carousel-control-next-icon{
        width:2rem;
        height:2rem;
      }

      .guide-card{
        padding:1.4rem 1rem;
      }

      .swatch{
        width:34px;
        height:34px;
      }

      .swatch.x-mark::before,
      .swatch.x-mark::after{
        width:48px;
      }

      .entourage-mobile-2 > [class*="col-"]{
        width:50%;
        flex:0 0 auto;
      }

      .gallery-item{
        height:200px;
      }

      .gallery-overlay{
        opacity:1;
        background:linear-gradient(to top, rgba(0,0,0,.28), rgba(0,0,0,.03));
      }

      .faq-top-grid .col-4{
        width:33.3333%;
      }

      .reminder-card{
        min-height:150px;
        border-radius:22px;
        padding:1rem .55rem;
      }

      .reminder-icon-wrap{
        width:54px;
        height:54px;
      }

      .reminder-icon{
        width:26px;
        height:26px;
      }

      .reminder-label{
        font-size:1.02rem;
        line-height:1.18;
      }

      .faq-title{
        font-size:2.2rem;
        margin-top:1.55rem;
        margin-bottom:1rem;
      }

      .fact-item h3{
        font-size:1.38rem;
      }

      .fact-item p{
        font-size:1rem;
        line-height:1.72;
        padding:0 .2rem;
      }

      .map-frame{
        height:220px;
      }

      .rsvp-button{
        min-width:190px;
      }
    }
  </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg fixed-top">
    <div class="container">
      <a class="navbar-brand" href="#home">
        <img src="fmlogo.png" alt="FM Logo" class="nav-logo">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="#story">Story</a></li>
          <li class="nav-item"><a class="nav-link" href="#celebration">Celebration</a></li>
          <li class="nav-item"><a class="nav-link" href="#attire">Wedding Attire</a></li>
          <li class="nav-item"><a class="nav-link" href="#entourage">Entourage</a></li>
          <li class="nav-item"><a class="nav-link" href="#gallery">Gallery</a></li>
          <li class="nav-item"><a class="nav-link" href="#reminders">Reminders</a></li>
          <li class="nav-item"><a class="nav-link" href="#rsvp">RSVP</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <section id="home" class="hero">
    <div class="container">
      <div class="hero-wrap">
        <div class="hero-panel">
          <div class="hero-overline">Wedding Invitation</div>
          <h1 class="hero-names">Faulo &amp; Marvie</h1>
          <div class="hero-date">October 18, 2026 | Sunday</div>
          <p class="hero-place">Nature’s Village Resort, Talisay Highway, Talisay City, Negros Occidental</p>

          <div class="hero-actions">
            <a href="#rsvp" class="hero-btn hero-btn-primary">RSVP Now</a>
            <a href="#save-date" class="hero-btn hero-btn-secondary">See Details</a>
          </div>

          <div class="hero-verse">
            <strong>He has made everything beautiful in its time.</strong>
            <span>Ecclesiastes 3:11</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="save-date" class="save-the-date section-padding floral-corner">
    <div class="container">
      <div class="save-wrap">
        <div class="save-icon-row">
          <div class="save-icon-side">~</div>
          <div class="save-icon-center">♡</div>
          <div class="save-icon-side">~</div>
        </div>

        <div class="save-intro-line">You are invited to the wedding of</div>
        <div class="save-intro-names">Faulo &amp; Marvie</div>

        <div class="save-label">Save the Date</div>
        <div class="save-date-line">October 18, 2026 | Sunday</div>
        <div class="save-location">Nature’s Village Resort, Talisay Highway, Talisay City, Negros Occidental</div>

        <div class="countdown-wrap">
          <div class="countdown">
            <div>
              <div class="count-number" id="days">00</div>
              <div class="count-label">Days</div>
            </div>
            <div>
              <div class="count-number" id="hours">00</div>
              <div class="count-label">Hours</div>
            </div>
            <div>
              <div class="count-number" id="minutes">00</div>
              <div class="count-label">Mins</div>
            </div>
            <div>
              <div class="count-number" id="seconds">00</div>
              <div class="count-label">Secs</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="story" class="section-padding floral-corner">
    <div class="container">
      <h2 class="section-title mb-5">Our Story</h2>

      <div class="row g-4 align-items-stretch">
        <div class="col-lg-6">
          <div id="storyCarousel" class="carousel slide carousel-fade story-img-wrap" data-bs-ride="carousel" data-bs-interval="3500">
            <div class="carousel-inner h-100">
              <div class="carousel-item active h-100">
                <img src="4.jpg" alt="Our Story 1" class="story-img">
              </div>
              <div class="carousel-item h-100">
                <img src="3.jpg" alt="Our Story 2" class="story-img">
              </div>
              <div class="carousel-item h-100">
                <img src="2.jpg" alt="Our Story 3" class="story-img">
              </div>
            </div>

            <button class="carousel-control-prev story-carousel-btn" type="button" data-bs-target="#storyCarousel" data-bs-slide="prev" aria-label="Previous story image">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next story-carousel-btn" type="button" data-bs-target="#storyCarousel" data-bs-slide="next" aria-label="Next story image">
              <span class="carousel-control-next-icon"></span>
            </button>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="story-card soft-card floral-corner">
            <div class="story-card-inner">
              <div class="story-step">
                <p>It all started with chit chat — one ordinary day that turned extraordinary.</p>
              </div>
              <div class="story-step">
                <p>What began as casual conversations turned into deep midnight talks and shared dreams that made our hearts feel at home.</p>
              </div>
              <div class="story-step">
                <p>This moment proves that distance means nothing when love is real.</p>
              </div>
              <div class="story-step">
                <p>Long distance is finally over.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="celebration" class="section-padding floral-corner">
    <div class="container">
      <h2 class="section-title">The Celebration</h2>
      <p class="section-subtitle">One venue, one shared location, and a smooth transition from ceremony to reception.</p>

      <div class="soft-card celebration-card">
        <div class="row g-4 align-items-stretch">
          <div class="col-lg-5">
            <div class="celebration-visual">
              <img src="3.jpg" alt="Celebration venue">
            </div>
          </div>

          <div class="col-lg-7">
            <div class="celebration-content">
              <div class="eyebrow">Wedding Day Details</div>
              <h3 class="detail-title">Garden Ceremony • Indoor Reception</h3>
              <div class="detail-meta">Nature’s Village Resort • Talisay City, Negros Occidental</div>
              <p>The ceremony will be held in the garden, followed by an indoor reception in the same venue. Guests may stay in one location throughout the celebration.</p>

              <div class="row g-3 mt-1 mb-4">
                <div class="col-sm-6 col-lg-3">
                  <div class="mini-card">
                    <h4>Guest Arrival</h4>
                    <p>2:00 PM</p>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="mini-card">
                    <h4>Ceremony</h4>
                    <p>Garden · 3:00 PM</p>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="mini-card">
                    <h4>Glazing Table</h4>
                    <p>5:00 PM</p>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="mini-card">
                    <h4>Reception</h4>
                    <p>Indoor · 6:00 PM</p>
                  </div>
                </div>
              </div>

              <div class="eyebrow">Venue Map</div>
              <h3 class="detail-title">Shared Venue Location</h3>
              <p>Both parts of the event will happen in the same place, so only one location is needed for guests.</p>

              <iframe
                class="map-frame"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps?q=Nature%27s%20Village%20Resort%20Talisay%20Negros%20Occidental&output=embed">
              </iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="attire" class="section-padding floral-corner">
    <div class="container">
      <h2 class="section-title">Wedding Attire</h2>
      <p class="section-subtitle">A soft, polished palette of blush pink, butter yellow, and refined neutrals.</p>

      <div class="soft-card guide-card floral-corner">
        <div class="row g-5 align-items-center">
          <div class="col-lg-5">
            <p class="guide-copy">
              Formal or semi-formal attire is warmly requested. We would truly appreciate our guests wearing polished pieces in soft and muted tones for a graceful and cohesive look.
            </p>
            <p class="guide-copy mb-0">
              Shades from blush, butter yellow, champagne, beige, taupe, and brown are welcome.
            </p>
          </div>

          <div class="col-lg-7">
            <div class="palette-strip">
              <div class="swatches">
                <div class="swatch" style="background:#f5e6ab"></div>
                <div class="swatch" style="background:#f3d8df"></div>
                <div class="swatch" style="background:#eadfd6"></div>
                <div class="swatch" style="background:#d7c4b6"></div>
                <div class="swatch" style="background:#a37c57"></div>
              </div>
              <p class="palette-caption">A soft floral palette with blush, butter yellow, and refined neutrals.</p>
            </div>

            <div class="guide-no-row">
              <div class="swatch x-mark" style="background:#7f145d"></div>
              <div class="swatch x-mark" style="background:#6431a9"></div>
              <div class="swatch x-mark" style="background:#93c400"></div>
              <div class="swatch x-mark" style="background:#ffd800"></div>
              <div class="swatch x-mark" style="background:#1fa4f2"></div>
              <div class="swatch x-mark" style="background:#ff0000"></div>
            </div>

            <p class="guide-note-small mt-3">Please avoid bright, neon, or highly saturated colors to keep the theme consistent.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

